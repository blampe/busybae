#!/usr/bin/env bash
# tools/bazel — self-installing busybae hook for bazelisk.
#
# Bazelisk automatically execs $WORKSPACE/tools/bazel if present, giving
# us a place to fire the busybae poke and keep cache GC alive without any
# per-invocation Bazel-run recursion.
#
# This file was generated by `busybae install-wrapper`. Regenerate it by
# rerunning that command; do not edit by hand.
#
# Pinned busybae version: {{.Version}}
# Release URL:            {{.ReleaseURL}}
set -euo pipefail

BUSYBAE_VERSION="{{.Version}}"
BUSYBAE_RELEASE_URL="{{.ReleaseURL}}"

# --- pass-through triggers ------------------------------------------------
# BUSYBAE_DISABLE: explicit opt-out for the wrapper (any non-empty value).
# CI:              set by virtually every CI system (GitHub Actions,
#                  GitLab CI, CircleCI, Travis, Buildkite, Vercel, etc.).
#                  A single-shot CI build won't benefit from the daemon,
#                  and starting one just wastes time and log noise.
if [[ -n "${BUSYBAE_DISABLE:-}" || -n "${CI:-}" ]]; then
    export BAZELISK_SKIP_WRAPPER=true
    exec bazelisk "$@"
fi

# --- platform detection ---------------------------------------------------
os=$(uname -s | tr '[:upper:]' '[:lower:]')
arch=$(uname -m)
case "$arch" in
    arm64|aarch64) arch=arm64 ;;
    x86_64|amd64)  arch=amd64 ;;
    *)
        # Unsupported CPU. Pass through — busybae is a best-effort helper.
        export BAZELISK_SKIP_WRAPPER=true
        exec bazelisk "$@"
        ;;
esac
platform="${os}_${arch}"

case "$platform" in
{{- range .Platforms }}
    "{{.Key}}") sha="{{.SHA}}" ;;
{{- end }}
    *)
        export BAZELISK_SKIP_WRAPPER=true
        exec bazelisk "$@"
        ;;
esac

# --- cache-materialize (first-run download only) --------------------------
cache_root="${XDG_CACHE_HOME:-$HOME/.cache}/busybae"
bin_dir="$cache_root/$BUSYBAE_VERSION/$platform"
bin="$bin_dir/busybae"

if [[ ! -x "$bin" ]]; then
    tmp=$(mktemp -d "${TMPDIR:-/tmp}/busybae-dl.XXXXXX")
    trap 'rm -rf "$tmp"' EXIT
    url="$BUSYBAE_RELEASE_URL/v${BUSYBAE_VERSION}/busybae-${platform}.tar.gz"
    ok=1
    if command -v curl >/dev/null 2>&1; then
        curl -fsSL "$url" -o "$tmp/dl.tgz" || ok=0
    elif command -v wget >/dev/null 2>&1; then
        wget -qO "$tmp/dl.tgz" "$url" || ok=0
    else
        ok=0
    fi
    if (( ok )); then
        if command -v sha256sum >/dev/null 2>&1; then
            got=$(sha256sum "$tmp/dl.tgz" | awk '{print $1}')
        else
            got=$(shasum -a 256 "$tmp/dl.tgz" | awk '{print $1}')
        fi
        if [[ "$got" == "$sha" ]]; then
            tar -xzf "$tmp/dl.tgz" -C "$tmp"
            mkdir -p "$bin_dir"
            # Atomic install via same-fs rename.
            mv "$tmp/busybae" "$bin.tmp.$$"
            chmod +x "$bin.tmp.$$"
            mv "$bin.tmp.$$" "$bin"
        else
            echo "busybae: checksum mismatch for $url" >&2
            echo "  want $sha" >&2
            echo "  got  $got"  >&2
            echo "busybae: wrapper will pass through this build" >&2
        fi
    fi
fi

# --- hot path -------------------------------------------------------------
if [[ -x "$bin" ]]; then
    # Fire and forget; a broken daemon must never break a build.
    "$bin" poke >/dev/null 2>&1 &
fi

export BAZELISK_SKIP_WRAPPER=true
exec bazelisk "$@"
